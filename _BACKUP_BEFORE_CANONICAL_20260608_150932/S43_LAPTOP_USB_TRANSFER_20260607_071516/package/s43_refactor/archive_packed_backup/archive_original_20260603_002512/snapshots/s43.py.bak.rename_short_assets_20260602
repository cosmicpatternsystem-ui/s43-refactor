    @staticmethod
    def _lvl_amt(x: Any) -> float:
        if isinstance(x, dict):
            for k in ("amount", "qty", "volume", "size", "q"):
                if k in x:
                    try:
                        return float(x.get(k) or 0.0)
                    except Exception:
                        return 0.0
        if isinstance(x, (list, tuple)) and len(x) >= 2:
            try:
                return float(x[1] or 0.0)
            except TradingHalt:
                raise
            except Exception:
                return 0.0
        return 0.0
