            return

        if pos is None and str(getattr(sig, "action", "") or "").strip().upper() == "BUY" and bool(getattr(self.cfg, "phoenix_enabled", True)):
            gate_mode = str(getattr(self.cfg, "phoenix_gate_mode", "soft") or "soft").strip().lower()
            try:
