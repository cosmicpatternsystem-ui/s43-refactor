def _recorder_child_main(args: Any) -> None:
    """SQLite tick/order recorder child process.

    Native replacement for the old subprocess '-c' embedded script.
    """
    db_path = str(getattr(args, "db", "") or os.getenv("RECORD_DB_PATH") or "raz_ticks.sqlite")
    try:
        timeout_sec = float(getattr(args, "recorder_timeout_sec", 30.0) or 30.0)
    except Exception:
        timeout_sec = 30.0
    flush_sec = float(_env_float("RECORDER_FLUSH_SEC", 1.0))
    batch_max = int(_env_int("RECORDER_BATCH_MAX", 250))
    conn = sqlite3.connect(db_path, timeout=timeout_sec)
    conn.execute("PRAGMA journal_mode=WAL;")
    conn.execute("PRAGMA synchronous=NORMAL;")
    conn.execute("PRAGMA busy_timeout=5000;")
    conn.execute(
        "CREATE TABLE IF NOT EXISTS ticks (ts REAL NOT NULL, wallet TEXT NOT NULL, symbol TEXT NOT NULL, "
        "bid REAL, ask REAL, mid REAL, spr_bps REAL, score REAL, equity REAL, quote_free REAL, asset_free REAL);"
    )
    conn.execute("CREATE INDEX IF NOT EXISTS idx_ticks_ws ON ticks(wallet, symbol, ts);")
    conn.execute(
        "CREATE TABLE IF NOT EXISTS orders (ts REAL NOT NULL, wallet TEXT NOT NULL, symbol TEXT NOT NULL, "
        "side TEXT NOT NULL, qty REAL, price REAL, notional REAL, ok INTEGER, order_id TEXT, raw TEXT);"
    )
    conn.execute("CREATE INDEX IF NOT EXISTS idx_orders_ws ON orders(wallet, symbol, ts);")
    conn.commit()
    batch_ticks: list[tuple] = []
    batch_orders: list[tuple] = []
    last_flush = time.time()
    def _flush(now: float) -> None:
        nonlocal last_flush
        if not batch_ticks and not batch_orders:
            return
        cur = conn.cursor()
        if batch_ticks:
            cur.executemany(
                "INSERT INTO ticks(ts,wallet,symbol,bid,ask,mid,spr_bps,score,equity,quote_free,asset_free) "
                "VALUES (?,?,?,?,?,?,?,?,?,?,?)",
                batch_ticks,
            )
        if batch_orders:
            cur.executemany(
                "INSERT INTO orders(ts,wallet,symbol,side,qty,price,notional,ok,order_id,raw) "
                "VALUES (?,?,?,?,?,?,?,?,?,?)",
                batch_orders,
            )
        conn.commit()
        batch_ticks.clear()
        batch_orders.clear()
        last_flush = now
    try:
        for line in sys.stdin:
            try:
                obj = json.loads(line)
                k = obj.get("k")
                r = obj.get("r")
                if k == "tick":
                    if isinstance(r, (list, tuple)):
                        batch_ticks.append(tuple(r))
                elif k == "order":
                    if isinstance(r, (list, tuple)):
                        batch_orders.append(tuple(r))
                now = time.time()
                if (now - last_flush) >= flush_sec or (len(batch_ticks) + len(batch_orders)) >= batch_max:
                    _flush(now)
            except Exception:
                try:
                    conn.rollback()
                except Exception:
                    pass
    finally:
        try:
            _flush(time.time())
        except Exception:
            pass
        try:
            conn.close()
        except Exception:
            pass

