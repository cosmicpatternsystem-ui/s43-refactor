                    scheme = "Bearer"
            except Exception:
                pass
        try:
            t = re.sub(r"\s+", "", t)
        except Exception:
            t = t.replace(" ", "").replace("\n", "").replace("\r", "").replace("\t", "")
        return scheme, t
