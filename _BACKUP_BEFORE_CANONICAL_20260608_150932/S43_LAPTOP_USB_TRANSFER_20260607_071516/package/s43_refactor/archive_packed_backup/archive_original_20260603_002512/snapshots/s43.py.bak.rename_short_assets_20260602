            hard_fail_ttl = float(os.getenv("DEPTH_HARD_FAIL_TTL_SEC", "3600" if _env_bool("TERMUX_MODE", False) else "1800") or 1800.0)
        except Exception:
            hard_fail_ttl = 1800.0
        hard_fail_ttl = max(60.0, float(hard_fail_ttl))
