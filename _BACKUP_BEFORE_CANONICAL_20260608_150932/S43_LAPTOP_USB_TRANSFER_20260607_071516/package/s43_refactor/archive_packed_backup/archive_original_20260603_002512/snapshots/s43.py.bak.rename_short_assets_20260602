def _record_why_no_trade(bot: Any, *, wallet: str = "", sym: str = "", status: str = "", reason: str = "", meta: dict | None = None) -> None:
    """Record a structured, high-signal explanation for why ENTRY is blocked or trade is skipped.

    This is meant for dashboards/logs, not for decision making.
    Categories are coarse and stable: WARMUP/NO_DATA/LOW_CONF/POLICY/HEALTH/SAFE/THROTTLE/RISK/REGIME.
    """
    try:
        now = float(time.time())
    except Exception:
        now = 0.0
    try:
        ru = str(reason or "").upper().strip()
    except Exception:
        ru = ""
    m = dict(meta or {})
    tags: list[str] = []
    def _add(t: str) -> None:
        t = str(t or "").strip().upper()
        if not t:
            return
        if t not in tags:
            tags.append(t)
    if ("SAFE" in ru) or ru.startswith("NET_SAFE") or ("NET_SAFE" in ru):
        _add("SAFE")
    pol = ""
    try:
        pol = str(m.get("policy") or "")
    except Exception:
        pol = ""
    pu = pol.upper()
    if ("HEALTH" in ru) or ("_HW_" in ru) or ("DENY_" in ru) or ("DENY_" in pu) or ("HEALTH_STATE" in (str(m.keys()).upper())):
        _add("HEALTH")
        _add("POLICY")
    if ("WARMUP" in ru) or ru.startswith("WAIT") or ("INIT" in ru) or ("DENY_INIT" in ru) or ("BOOT" in ru):
        _add("WARMUP")
    if ru in ("WAIT_X", "WAIT") or ("THROTTLE" in ru) or ("ENTRY_THROTTLED" in ru):
        _add("THROTTLE")
    for k in ("NO_DATA","NODATA","NOBOOK","NO_PRICE","NOFEED","STALE","INVALID","DATA_SOFT","DATA_DEGRADED","AGE?"):
        if k in ru or k in pu:
            _add("NO_DATA")
            break
    if ("LOW_CONF" in ru) or ru.startswith("LOW_SC") or ("LOW_SC" in ru) or ("PARISA" in ru and "VETO" in ru):
        _add("LOW_CONF")
    for k in ("REGIME","FLAT","RANGE","SIDEWAYS"):
        if k in ru:
            _add("REGIME")
            break
    for k in ("MAX_POS","LOCK","SPREAD","VOL","LIQ","TREND","DYN","CAP","NOTIONAL","PROFIT"):
        if k in ru:
            _add("RISK")
            _add("POLICY")
            break
    if not tags and ru:
        _add("POLICY")
    payload = {
        "ts": now,
        "wallet": str(wallet or ""),
        "sym": str(sym or ""),
        "status": str(status or ""),
        "reason": str(reason or ""),
        "policy": str(pol or ""),
        "tags": list(tags),
        "meta": m,
    }
    try:
        setattr(bot, "_why_no_trade", payload)
    except Exception:
        pass
    try:
        w0 = str(payload.get("wallet") or "").strip()
        s0 = str(payload.get("sym") or "").strip()
        key = ""
        if w0 and s0:
            key = f"{w0}:{s0}"
        else:
            key = w0 or s0 or ""
        by = getattr(bot, "_why_no_trade_by_key", None)
        if not isinstance(by, dict):
            by = {}
        if key:
            by[key] = payload
            setattr(bot, "_why_no_trade_by_key", by)
    except Exception:
        pass
    try:
        is_entry = False
        try:
            st0 = str(payload.get("status") or "").upper().strip()
        except Exception:
            st0 = ""
        if st0.startswith("ENTRY"):
            is_entry = True
        try:
            if bool(m.get("entry_attempt", False)):
                is_entry = True
        except Exception:
            pass
        if is_entry:
            setattr(bot, "_last_entry_attempt", payload)
    except Exception:
        pass
