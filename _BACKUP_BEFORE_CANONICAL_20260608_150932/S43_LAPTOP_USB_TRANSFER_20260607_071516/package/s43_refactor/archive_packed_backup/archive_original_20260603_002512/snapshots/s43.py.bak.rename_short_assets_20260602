                fields={
                    "sig_action": str(getattr(sig, "action", "") or ""),
                    "sig_reason": str(getattr(sig, "reason", "") or ""),
                    "sig_score": float(getattr(sig, "score", 0.0) or 0.0),
                    "sig_conf": float(getattr(sig, "confidence", 0.0) or 0.0),
