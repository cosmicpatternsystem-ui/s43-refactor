                w.last_event = f"SANITY_HALT {sym}"
                _set_engine("Hold", f"SANITY_HALT:{str(getattr(w,'sanity_reason','') or '').strip() or 'ON'}", reject=True, meta={"sym": sym})
                if not has_pos:
