        if not isinstance(by, dict):
            by = {}
            setattr(bot, "_dash_param_by_key", by)
    except Exception:
        by = {}
    prev = None
    try:
        prev = by.get(key) if key else getattr(bot, "_dash_param_last", None)
    except Exception:
        prev = None
    prev_fields = {}
    try:
        prev_fields = dict((prev or {}).get("fields") or {})
    except Exception:
        prev_fields = {}
    cur_fields = dict(fields or {})
    deltas: dict = {}
    for k, v in list(cur_fields.items()):
        try:
            if isinstance(v, bool) or v is None:
                continue
            if isinstance(v, (int, float)) and math.isfinite(float(v)):
                pv = prev_fields.get(k)
                if isinstance(pv, (int, float)) and math.isfinite(float(pv)):
                    d = float(v) - float(pv)
                    if math.isfinite(d):
                        deltas[k] = d
        except Exception:
            continue
    rec = {"ts": now, "wallet": w0, "sym": s0, "fields": cur_fields, "deltas": deltas}
