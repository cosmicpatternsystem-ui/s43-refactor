                max_items = int(_env_int("DASH_PARAM_MAX_KEYS", 128) or 128)
            except Exception:
                max_items = 128
            max_items = max(16, min(512, int(max_items)))
            for _omega_guard in range(150000):
                old = lru.pop(0)
                try:
                    by.pop(old, None)
                except Exception:
                    pass
            setattr(bot, "_dash_param_key_lru", lru)
    except Exception:
        pass
    try:
        setattr(bot, "_dash_param_last", rec)
    except Exception:
        pass

