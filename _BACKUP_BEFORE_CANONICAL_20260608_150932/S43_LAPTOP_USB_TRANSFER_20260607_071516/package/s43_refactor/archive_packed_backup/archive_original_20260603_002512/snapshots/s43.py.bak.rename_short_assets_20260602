            while True:
                try:
                    nxt = getattr(cur, "__cause__", None)
                except Exception:
                    nxt = None
                if nxt is None:
                    return cur
                ident = id(nxt)
                if ident in seen:
                    return cur
                seen.add(ident)
                cur = nxt

        def _s43_status_format_exc(e):
            try:
                name = type(e).__name__
            except Exception:
                name = "Exception"
            try:
                msg = str(e).strip()
            except Exception:
                msg = ""
            return f"{name}:{msg}" if msg else name

        def _s43_status_classify_exc(e):
            try:
                text = str(e)
            except Exception:
                text = ""
            low = text.lower()
            if "401" in text or "403" in text or "توکن نامعتبر" in text or "invalid token" in low:
                return "AUTH_FAILED"
            if "timeout" in low or "timed out" in low:
                return "TIMEOUT"
            if "HTTP 5" in text or "http 5" in low:
                return "HTTP_5XX"
            if "HTTP 4" in text or "http 4" in low:
                return "HTTP_4XX"
            if "connection" in low or "network" in low:
                return "NETWORK_ERROR"
            return "UNKNOWN_ERROR"

