    p.add_argument("--live", action="store_true", help="Enable live trading (LIVE_TRADING=1).")
    p.add_argument("--dry-run", action="store_true", help="(Disabled) DRY mode is not available in this LIVE-only build.")
    p.add_argument("--watchdog", action="store_true", help="Run parent watchdog supervisor.")
    p.add_argument("--child", action="store_true", help=argparse.SUPPRESS)
    p.add_argument("--dash", action="store_true", help="Enable TUI dashboard (requires rich).")
    p.add_argument("--record", action="store_true", help="Enable tick recorder (SQLite).")
