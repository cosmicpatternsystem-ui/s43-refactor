    p.add_argument("--symbols", type=str, default="", help="Comma-separated symbols override (e.g., BTCIRT,USDTIRT).")
    p.add_argument("--wallets", type=str, default="", help="Comma-separated wallet slots (e.g., 1,2,3).")
    p.add_argument("--backtest", type=str, default="", help="Backtest symbol from RECORD_DB_PATH ticks.")
