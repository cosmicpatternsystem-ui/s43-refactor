                                    if fp <= 0.0:
                                        try:
                                            fp2 = float(OrderJournal._order_avg_px(raw0, fq2) or 0.0)
                                        except Exception:
                                            fp2 = 0.0
                                        if fp2 > 0.0:
                                            fp = fp2
                        except Exception:
                            pass
                        if fq <= 0.0:
