def _env_bool(name: str, default=False):
    try:
        v = os.getenv(name)
    except Exception:
        return bool(default)
    if v is None:
        return bool(default)
    s = str(v).strip().lower()
    if s in ("1", "true", "yes", "y", "on"):
        return True
    if s in ("0", "false", "no", "n", "off", ""):
        return False
    return bool(default)


def _env_float(name: str, default: float = 0.0) -> float:
    """Read float from environment safely."""
    try:
        v = os.getenv(name)
    except Exception:
        return float(default)
    if v is None:
        return float(default)
    try:
        s = str(v).strip()
        if s == "":
            return float(default)
        return float(s)
    except Exception:
        return float(default)



def _env_str(name: str, default: str | None = None) -> str:
    """Read string from environment safely."""
    try:
        v = os.getenv(name)
    except Exception:
        return "" if default is None else str(default)
    if v is None:
        return "" if default is None else str(default)
    try:
        return str(v)
    except Exception:
        return "" if default is None else str(default)



def _canon_symbol(sym: str) -> str:
    """Normalize trading symbol safely."""
    try:
        s = str(sym or "").strip().upper()
    except Exception:
        return ""
    if not s:
        return ""
    s = s.replace("/", "").replace("-", "").replace("_", "").replace(" ", "")
    return s



def _env_int(name: str, default: int = 0) -> int:
    """Read integer from environment safely."""
    try:
        v = os.getenv(name)
    except Exception:
        return int(default)
    if v is None:
        return int(default)
    try:
        s = str(v).strip()
        if s == "":
            return int(default)
        return int(float(s))
    except Exception:
        return int(default)



def clamp(x, lo, hi):
    """Clamp x into [lo, hi] safely."""
    try:
        x = float(x)
        lo = float(lo)
        hi = float(hi)
    except Exception:
        try:
            return lo
        except Exception:
            return x
    if lo > hi:
        lo, hi = hi, lo
    if x < lo:
        return lo
    if x > hi:
        return hi
    return x



