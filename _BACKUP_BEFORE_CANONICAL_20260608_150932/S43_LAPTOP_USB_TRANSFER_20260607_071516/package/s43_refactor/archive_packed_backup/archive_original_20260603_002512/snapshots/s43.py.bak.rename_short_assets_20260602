    def _compute_assets_value(self, assets: Dict[str, float], mkt: Orch22MarketState) -> float:
        quote = str(getattr(self.cfg, "quote", "IRT") or "IRT").upper()
        total = 0.0
        for ccy, amt in (assets or {}).items():
            c = str(ccy or "").upper().strip()
